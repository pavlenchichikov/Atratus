# https://editorconfig.org - consistent formatting across editors/IDEs.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 120

[*.{yml,yaml,json,toml,cfg,ini}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# Windows launchers must keep CRLF line endings.
[*.bat]
end_of_line = crlf
